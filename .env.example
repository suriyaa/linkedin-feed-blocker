# AMO (addons.mozilla.org) signing credentials.
# Copy this file to ".env" and fill in your values. NEVER commit ".env".
# Generate credentials at: https://addons.mozilla.org/developers/addon/api/key/

# JWT issuer — looks like "user:12345:67"
WEB_EXT_API_KEY=

# JWT secret — a long hex string. Keep this private.
WEB_EXT_API_SECRET=
