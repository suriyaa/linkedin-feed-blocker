{
  "name": "linkedin-feed-blocker",
  "version": "1.0.0",
  "description": "Browser extension that blocks the LinkedIn home feed while keeping the rest of LinkedIn usable. Firefox-first, Chrome/Edge/Safari compatible.",
  "private": true,
  "type": "module",
  "scripts": {
    "icons": "python3 scripts/make-icons.py",
    "build": "node scripts/build.mjs",
    "build:firefox": "node scripts/build.mjs firefox",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:edge": "node scripts/build.mjs edge",
    "build:safari": "node scripts/build.mjs safari",
    "clean": "rm -rf dist",
    "zip": "npm run build && node scripts/zip.mjs"
  },
  "license": "GPL-3.0-or-later"
}
